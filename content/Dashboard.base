views:
  - type: table
    name: Table
    filters:
      and:
        - file.folder == "content/University/Syllabus"
    order:
      - status
      - want
      - file.name
      - required
      - url
    sort:
      - property: status
        direction: ASC
      - property: want
        direction: DESC
    cardSize: 270
    columnSize:
      file.name: 395
